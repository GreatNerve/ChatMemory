# Repo-relative data root (default: ../data from backend cwd)

DATA_ROOT=../data



# Multilingual E5 — strong Hinglish/English retrieval; re-ingest after changing
EMBED_MODEL=intfloat/multilingual-e5-large

# Embed device: auto (CUDA if available) | cuda | cpu
EMBED_DEVICE=auto



# Vector index: chroma (default) | file (JSON fallback) | auto

VECTOR_STORE=chroma



API_HOST=0.0.0.0

API_PORT=8000



CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000



# Required — Q&A rewrite/rerank/answer and persona chat

GEMINI_API_KEY=

# Or set GOOGLE_API_KEY instead of GEMINI_API_KEY
GEMINI_MODEL=gemini-3.5-flash



# Persona activation message gates

LORA_MIN_MESSAGES=200

LORA_THIN_MIN_MESSAGES=50



# ThinkingPanel: when false (default) the frontend hides the INPUT section by default.
# Users can still toggle the setting per-session via the UI button.

THINKING_SHOW_INPUT=false

